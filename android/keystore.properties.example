# Copy to android/keystore.properties (gitignored) for signed release APKs.
# Generate keystore: keytool -genkey -v -keystore medvault-demo.keystore -alias medvault -keyalg RSA -keysize 2048 -validity 10000
#
# storeFile=../medvault-demo.keystore
# storePassword=your-store-password
# keyAlias=medvault
# keyPassword=your-key-password
