{
  "mcpServers": {
    "medvault": {
      "transport": "stdio",
      "command": "node",
      "args": [
        "<REPO_ROOT>/mcp-server/dist/index.js"
      ],
      "env": {
        "SEPOLIA_RPC_URL": "${SEPOLIA_RPC_URL}",
        "MEDVAULT_SUBGRAPH_URL": "${MEDVAULT_SUBGRAPH_URL}",
        "MCP_PRIVATE_KEY": "${MCP_PRIVATE_KEY}"
      }
    }
  }
}
