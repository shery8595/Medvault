{
  "mcpServers": {
    "medvault": {
      "command": "node",
      "args": [
        "E:/medvault/mcp-server/dist/index.js"
      ],
      "env": {
        "SEPOLIA_RPC_URL": "${env:SEPOLIA_RPC_URL}",
        "MEDVAULT_SUBGRAPH_URL": "${env:MEDVAULT_SUBGRAPH_URL}",
        "MCP_PRIVATE_KEY": "${env:MCP_PRIVATE_KEY}"
      }
    }
  }
}
