{
  "name": "@medvault/ai",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./lib": "./dist/exports.js"
  },
  "scripts": {
    "build": "tsup src/index.ts src/exports.ts --format esm --clean",
    "dev": "tsup src/index.ts --format esm --watch --onSuccess \"node dist/index.js\"",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@medvault/core": "*",
    "ajv": "^8.17.1",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "ethers": "6.16.0",
    "express": "^4.21.0",
    "multer": "^1.4.5-lts.1",
    "openai": "^4.104.0",
    "pdf-parse": "^1.1.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.12",
    "@types/pdf-parse": "^1.1.4",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3"
  }
}
