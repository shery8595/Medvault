  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "cross-env NODE_OPTIONS=--max-old-space-size=8192 vite build",
    "build:prebuilt": "vite build",
    "build:vercel": "cross-env NODE_OPTIONS=--max-old-space-size=6144 vite build",
    "vercel:pull": "vercel pull --yes --environment=production",
    "vercel:pack": "node scripts/pack-vercel-static-output.mjs",
    "vercel:build": "npm run build && npm run vercel:pack",
    "vercel:deploy": "vercel deploy --prebuilt --prod",
    "vercel:ship": "npm run vercel:pull && npm run vercel:build && npm run vercel:deploy",
    "preview": "vite preview",
    "clean": "rimraf ./fhevmTemp ./artifacts ./cache ./coverage ./types ./coverage.json ./dist && npm run typechain",
    "compile": "cross-env TS_NODE_TRANSPILE_ONLY=true hardhat compile",
    "test": "node scripts/hardhat-test-suite.mjs default",
    "test:unit": "node scripts/hardhat-test-suite.mjs unit",
    "test:integration": "node scripts/hardhat-test-suite.mjs integration",
    "test:crypto": "node scripts/hardhat-test-suite.mjs crypto",
    "test:honk": "node scripts/hardhat-test-suite.mjs honk",
    "test:coverage": "hardhat coverage",
    "typechain": "cross-env TS_NODE_TRANSPILE_ONLY=true hardhat typechain",
    "build:circuit": "node scripts/compile-circuit.js",
    "generate:honk-verifier": "node scripts/generate-honk-verifier.js",
    "sync-abis": "node scripts/sync-abis.js",
    "deploy:vault:arb-sepolia": "hardhat run scripts/redeploy-screening-vault.ts --network arbitrumSepolia",
    "deploy:wiring:arb-sepolia": "hardhat run scripts/finish-wiring.ts --network arbitrumSepolia",
    "deploy:check-wiring:arb-sepolia": "hardhat run scripts/check-wiring-status.ts --network arbitrumSepolia",
    "deploy:chainlink-forwarder:arb-sepolia": "hardhat run scripts/set-chainlink-forwarder.ts --network arbitrumSepolia",
    "deploy:subgraph:sync": "node scripts/update-subgraph-yaml.js && npm run subgraph:deploy",
    "subgraph:set-start-near-head": "node scripts/set-subgraph-start-near-head.mjs",
    "subgraph:deploy:near-head": "node scripts/set-subgraph-start-near-head.mjs && node scripts/update-subgraph-yaml.js && node scripts/redeploy-subgraph.js",
    "subgraph:prepare": "npm run sync-abis && cd subgraph && npm run codegen && npm run build",
    "subgraph:deploy": "node scripts/redeploy-subgraph.js 0.1.2",
    "subgraph:deploy:studio": "cd subgraph && npm run deploy:studio"
  }
}
