# Privy (https://dashboard.privy.io) — required for app load
VITE_PRIVY_APP_ID=

# Reclaim (https://dev.reclaimprotocol.org) — “Upload initial record” source attestation
# APP_SECRET in Vite is visible to users; use a backend to sign requests in production.
VITE_RECLAIM_APP_ID=
VITE_RECLAIM_APP_SECRET=
# Provider from your Reclaim app (e.g. a lab portal or custom HTTPS template)
VITE_RECLAIM_PROVIDER_ID=
# Optional: attestation soft-expiry (seconds) stored client-side for reviewers; 0 or unset defaults to 90 days
# VITE_RECLAIM_ATTEST_TTL_SEC=7776000
# If not "false", user can skip Reclaim and go straight to the encrypt form
VITE_RECLAIM_ALLOW_SKIP=true

# Sponsor portal: any connected wallet can open / create trials. Set to "false" to require SponsorRegistry allowlist.
# VITE_SPONSOR_OPEN_ACCESS=false

# Optional: CoFHE ZK proof verifier (default: /cofhe-vrf on this origin — needs Vercel/proxy route)
# VITE_COFHE_VRF_VERIFIER_URL=https://testnet-cofhe-vrf.fhenix.zone

# Optional overrides
# VITE_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc
# Vite loads `.env.local` after `.env` — values in `.env.local` win. Vercel CLI often writes `.env.local`; if subgraph path looks wrong in the console, check that file too.
# Must match Studio Playground "Query URL" (id + slug + version). Slug: medvault-final
GRAPH_SUBGRAPH_SLUG=medvault-final
# v0.1.2: synced near chain head (start after early registrations — use on-chain isRegistered for profile).
VITE_SUBGRAPH_URL=https://api.studio.thegraph.com/query/1742459/medvault-final/v0.1.2
# One-time Hardhat only — set forwarder on MedVaultAutomation after Chainlink upkeep registration (not read by Vite)
# CHAINLINK_FORWARDER=0x...
# Dev defaults to same-origin /relay (Vite proxy). Override only if you need a direct URL:
# VITE_RELAYER_URL=https://medvault-relayer-production.up.railway.app
#
# Relayer service (relayer/server.js) — deploy separately; rejects finalize when not 100% eligible
# REGISTRY_ADDRESS=<MedVaultRegistry from addresses.json>
# SEMAPHORE_ADDRESS=<Semaphore from addresses.json>
# RELAYER_PRIVATE_KEY=
# RPC_URL or ARBITRUM_SEPOLIA_RPC_URL=
# FRONTEND_URL=https://med-vault.xyz (CORS allowlist for production; see relayer/.env.example)

# Optional: arb-sepolia-faucet service base URL (POST /drip). NOT a public faucet website.
# VITE_TESTNET_FAUCET_URL=https://your-faucet.up.railway.app
# Optional: which public faucet page opens when users click “Open testnet faucet” (default: QuickNode Arbitrum Sepolia)
# VITE_TESTNET_FAUCET_PAGE_URL=https://faucet.quicknode.com/arbitrum/sepolia
