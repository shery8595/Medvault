# Privy (https://dashboard.privy.io) — required for app load
VITE_PRIVY_APP_ID=

# Reclaim (https://dev.reclaimprotocol.org) — “Upload initial record” source attestation
# APP_SECRET in Vite is visible to users; use a backend to sign requests in production.
VITE_RECLAIM_APP_ID=
VITE_RECLAIM_APP_SECRET=
# Provider from your Reclaim app (e.g. a lab portal or custom HTTPS template)
VITE_RECLAIM_PROVIDER_ID=
# Optional: attestation soft-expiry (seconds) stored client-side for reviewers; 0 or unset defaults to 90 days
# VITE_RECLAIM_ATTEST_TTL_SEC=7776000
# If not "false", user can skip Reclaim and go straight to the encrypt form
VITE_RECLAIM_ALLOW_SKIP=true

# Sponsor portal: any connected wallet can open / create trials. Set to "false" to require SponsorRegistry allowlist.
# VITE_SPONSOR_OPEN_ACCESS=false

# Zama fhEVM relayer (default: same-origin /api/relayer/11155111 — needs Vercel/proxy route)
# VITE_ZAMA_RELAYER_URL=https://relayer.testnet.zama.org

# Optional overrides
# VITE_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
# VITE_SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
# Vite loads `.env.local` after `.env` — values in `.env.local` win. Vercel CLI often writes `.env.local`; if subgraph path looks wrong in the console, check that file too.
# Must match Studio Playground "Query URL" (id + slug + version).
GRAPH_SUBGRAPH_SLUG=medvault
# v0.1.3: all subgraph data sources synced to addresses.json (incl. attestation upgrade contracts).
VITE_SUBGRAPH_URL=https://api.studio.thegraph.com/query/1755644/medvault/v0.1.5-fhe
# One-time Hardhat only — set forwarder on MedVaultAutomation after Chainlink upkeep registration (not read by Vite)
# CHAINLINK_FORWARDER=0x...
# Dev defaults to same-origin /relay (Vite proxy). Override only if you need a direct URL:
# VITE_RELAYER_URL=https://medvault-relayer-production.up.railway.app
#
# Android APK (Capacitor) — see docs/ANDROID_APK.md
# Privy dashboard: allow https://localhost for WebView origin
# Relayer FRONTEND_URL=https://med-vault.xyz,https://localhost
# Optional overrides for APK builds (defaults in src/lib/mobile.ts):
# VITE_ZAMA_RELAYER_URL=https://relayer.testnet.zama.org
# VITE_RELAYER_URL=https://medvault-relayer-production.up.railway.app
#
# android/local.properties (gitignored, per machine):
# sdk.dir=C\:\\Users\\YOUR_USERNAME\\AppData\\Local\\Android\\Sdk
#
# Relayer service (relayer/server.js) — deploy separately; rejects finalize when not 100% eligible
# REGISTRY_ADDRESS=<MedVaultRegistry from addresses.json>
# SEMAPHORE_ADDRESS=<Semaphore from addresses.json>
# RELAYER_PRIVATE_KEY=
# RPC_URL or SEPOLIA_RPC_URL=
# FRONTEND_URL=https://med-vault.xyz (CORS allowlist for production; see relayer/.env.example)

# MedVault MCP server (mcp-server/) — see docs/MCP_SERVER.md
# MEDVAULT_SUBGRAPH_URL=  # same as VITE_SUBGRAPH_URL
# SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
# MCP_PRIVATE_KEY=  # sponsor/dev wallet for write tools (Sepolia only)
# MEDVAULT_SPONSOR_OPEN_ACCESS=true  # bypass SponsorRegistry in MCP (testnet)
# MCP_MAX_ETH_PER_TX=1
# MEDVAULT_RELAYER_URL=  # optional health check
# MCP_READ_ONLY=true  # disable write tools even if MCP_PRIVATE_KEY is set

# Optional: testnet faucet service base URL (POST /drip). NOT a public faucet website.
# VITE_TESTNET_FAUCET_URL=https://your-faucet.up.railway.app
# Optional: which public faucet page opens when users click “Open testnet faucet” (default: Sepolia)
# VITE_TESTNET_FAUCET_PAGE_URL=https://faucet.quicknode.com/ethereum/sepolia

# Hardhat deploy + scripts
# SEPOLIA_RPC_URL=
# PRIVATE_KEY=
